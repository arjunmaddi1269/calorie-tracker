# Application
APP_NAME="Calorie Tracker API"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/calorie_tracker
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/calorie_tracker_test

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:19006"]

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=calorie-tracker
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION=us-east-1

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# FatSecret API
FATSECRET_CLIENT_ID=your-client-id
FATSECRET_CLIENT_SECRET=your-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID_MONTHLY=price_monthly
STRIPE_PRICE_ID_ANNUAL=price_annual

# Email (SendGrid)
SENDGRID_API_KEY=SG.your-sendgrid-key
FROM_EMAIL=noreply@example.com

# Sentry
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_PHOTO_ANALYSIS=10/minute
RATE_LIMIT_API_DEFAULT=100/minute
FREE_TIER_DAILY_SCANS=5

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
